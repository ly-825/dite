# 应用基础配置
APP_NAME="Diet Delushan API"
SECRET_KEY=replace_with_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MySQL 连接配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DB=diet_delushan

# DashScope / OpenAI 兼容模型配置
DASHSCOPE_API_KEY=replace_with_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=60

# 允许跨域的前端地址，多个地址用英文逗号分隔
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
